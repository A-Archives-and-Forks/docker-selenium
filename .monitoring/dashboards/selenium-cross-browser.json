          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by(browser_name) (selenium_grid_session_queue_requests) / clamp_min(sum by(browser_name) (selenium_grid_node_stereotype_slots_total) - sum by(browser_name) (selenium_grid_sessions_active), 1)",
