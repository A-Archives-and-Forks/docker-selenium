          "range": false,
          "format": "table",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "browser_name",
                "browser_version",
                "Value"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "browser_name": 0,
              "browser_version": 1,
              "Value": 2
            },
            "renameByName": {
              "browser_name": "Browser",
              "browser_version": "Version",
              "Value": "Slots"
            }
          }
        }
