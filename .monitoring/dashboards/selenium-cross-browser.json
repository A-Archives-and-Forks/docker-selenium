          "expr": "round(100 *   (sum by(browser_name, browser_version) (selenium_grid_sessions_active)   OR (0 * sum by(browser_name, browser_version) (selenium_grid_node_stereotype_slots_total))) / sum by(browser_name, browser_version) (selenium_grid_node_stereotype_slots_total))",
