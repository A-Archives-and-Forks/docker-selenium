        {
          "id": "joinByField",
          "options": {
            "byField": "node_id",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time #A": true,
              "Time #B": true,
              "Time #C": true,
              "Time #D": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "status": true
            },
            "indexByName": {
              "node_id": 0,
              "Value #A": 1,
              "uri": 2,
              "version": 3,
              "os_name": 4,
              "os_arch": 5,
              "os_version": 6,
              "Value #B": 7,
              "Value #C": 8,
              "Value #D": 9
            },
            "renameByName": {
              "node_id": "Node ID",
              "Value #A": "Status",
              "uri": "URI",
              "version": "Version",
              "os_name": "OS",
              "os_arch": "Arch",
              "os_version": "OS Version",
              "Value #B": "Active Sessions",
              "Value #C": "Total Slots",
              "Value #D": "Status Duration (s)"
            }
          }
        }
