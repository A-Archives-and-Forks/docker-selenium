      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by(browser_name, browser_version, node_id) (last_over_time(selenium_grid_node_stereotype_slots_total[$__range]))",
