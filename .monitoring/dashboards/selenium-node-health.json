          "range": false,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "browser_name",
                "browser_version",
                "node_id",
                "Value"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "browser_name": 0,
              "browser_version": 1,
              "node_id": 2,
              "Value": 3
            },
            "renameByName": {
              "browser_name": "Browser",
              "browser_version": "Version",
              "node_id": "Node",
              "Value": "Slots"
            }
          }
        }
